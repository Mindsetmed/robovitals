{
  "name": "@mindset-vitals/web-sdk",
  "version": "2.6.0-2",
  "description": "Browser-first Web SDK for Vital-Core worker",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js"
    },
    "./worker": "./dist/worker.js"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "mindset-vitals-web-sdk-copy-worker-files": "./bin/copy-worker-files.js",
    "mindset-vitals-web-sdk-copy-vital-client-umd": "./bin/copy-vital-client-umd.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:sdk && npm run build:worker && npm run build:docs",
    "build:sdk": "vite build",
    "build:worker": "vite build --mode worker",
    "build:docs": "node scripts/build-docs.js",
    "build:release": "npm run build && node scripts/build-release.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "install:example": "cd examples/vanilla-js && npm install",
    "start:example": "cd examples/vanilla-js && npm start",
    "build:start:example": "npm run build && npm run start:example"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.21",
    "eventemitter3": "^5.0.1",
    "rawr": "^0.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.6",
    "jsdom": "^27.0.0",
    "lint-staged": "^15.2.10",
    "marked": "^17.0.0",
    "vite": "^6.3.5",
    "vite-plugin-static-copy": "^3.1.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ]
  },
  "keywords": [
    "vitals",
    "vital-core",
    "wasm",
    "mediapipe",
    "health",
    "biometrics"
  ],
  "author": "Mindset Vitals",
  "license": "UNLICENSED",
  "private": true
}

# Server Configuration
PORT=3015

# Mindset API Configuration
# Required for patient creation and vitals storage
MINDSET_API_URL="https://api-develop.mindsetmedical.com"
MINDSET_API_KEY="your-api-key-here"
CLINIC_ID="your-clinic-id-here"

# Notification Type
# VITAL-TRAC - Health and wellness tracking
# VITAL-CORE - FDA cleared medical vitals
# VITAL-CORE-RR - Respiratory rate variant
NOTIFICATION_TYPE="VITAL-TRAC"

# Available API URLs:
# Development: https://api-develop.mindsetmedical.com
# Staging: https://api-staging.mindsetmedical.com
# Production: https://api.mindsetmedical.com
# Local: http://localhost:3001

# Logging
# LOG_LEVEL=info
